{
  "name": "@your-scope/ui-kit",
  "version": "0.1.4",
  "description": "React UI component library built with TypeScript and Tailwind CSS",
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwind",
    "typescript",
    "design-system"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mihsta/ui-kit.git"
  },
  "homepage": "https://github.com/mihsta/ui-kit#readme",
  "bugs": {
    "url": "https://github.com/mihsta/ui-kit/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsc && vite build && npm run build:css",
    "build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/styles.css",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && npm publish --access public --provenance",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.15.0",
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/addon-links": "^9.0.0",
    "@storybook/addon-onboarding": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^9.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist"
  ]
}
